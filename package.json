		"test:watch": "vitest",
		"check": "biome check .",
		"lint": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"typescript": "^6",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@10.29.3",
	"engines": {
		"node": ">=20"
	}
}
