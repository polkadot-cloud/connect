{
	"name": "polkadot-cloud-connect",
	"private": true,
	"license": "GPL-3.0-only",
	"type": "module",
	"scripts": {
		"clear": "pnpm -r run clear",
		"build": "pnpm -r run build",
		"build:directory": "node builder/dist/index.js -t directory",
		"compile": "pnpm -r --if-present run compile",
