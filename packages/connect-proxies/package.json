{
	"name": "@polkadot-cloud/connect-proxies",
	"description": "Proxy account adaptor and hooks for @polkadot-cloud/connect",
	"version": "0.1.1",
	"license": "GPL-3.0-only",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"keywords": [
		"polkadot",
		"substrate",
		"wallet",
		"connect",
		"proxy",
		"react",
		"typescript"
	],
	"homepage": "https://github.com/polkadot-cloud/connect/tree/main/packages/connect-proxies/overview",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/polkadot-cloud/connect.git",
		"directory": "packages/connect-proxies"
	},
	"bugs": {
		"url": "https://github.com/polkadot-cloud/connect/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clear": "rm -rf node_modules dist tsconfig.tsbuildinfo",
		"check": "biome check .",
		"lint": "biome check --write .",
		"build": "tsup",
		"compile": "builder -t connect-proxies"
	},
	"dependencies": {
		"@dedot/chaintypes": "^0.263.0",
		"@polkadot-cloud/connect-core": "workspace:^",
		"@w3ux/hooks": "^2.4.4",
		"@w3ux/utils": "^3.1.1",
		"dedot": "^1.2.0",
		"rxjs": "^7.8.2"
	},
	"peerDependencies": {
		"@polkadot-cloud/connect": "^1",
		"react": "^19",
		"react-dom": "^19"
	},
	"devDependencies": {
		"@types/react": "^19",
		"builder": "workspace:*",
		"react": "^19",
		"tsup": "^8",
		"typescript": "^6"
	}
}
