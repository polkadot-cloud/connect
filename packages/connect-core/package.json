{
	"name": "@polkadot-cloud/connect-core",
	"description": "Core observables for extensions and accounts discovery",
	"version": "1.0.7",
	"license": "GPL-3.0-only",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./extensions": {
			"types": "./dist/extensions/index.d.ts",
			"import": "./dist/extensions/index.js",
			"require": "./dist/extensions/index.cjs"
		},
		"./accounts": {
			"types": "./dist/accounts/index.d.ts",
			"import": "./dist/accounts/index.js",
			"require": "./dist/accounts/index.cjs"
		},
		"./observables": {
			"types": "./dist/observables.d.ts",
			"import": "./dist/observables.js",
			"require": "./dist/observables.cjs"
		}
	},
	"keywords": [
		"polkadot",
		"substrate",
		"wallet",
		"connect",
		"extensions",
		"accounts",
		"observables",
		"rxjs",
		"typescript"
	],
	"homepage": "https://github.com/polkadot-cloud/connect#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/polkadot-cloud/connect.git",
		"directory": "packages/connect-core"
	},
	"bugs": {
		"url": "https://github.com/polkadot-cloud/connect/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clear": "rm -rf node_modules dist tsconfig.tsbuildinfo",
		"check": "biome check .",
		"lint": "biome check --write .",
		"build": "tsup",
		"compile": "builder -t connect-core"
	},
	"dependencies": {
		"@w3ux/extension-assets": "^2.2.5",
		"@w3ux/types": "^2.4.2",
		"@w3ux/util-dedot": "^1.0.0",
		"@w3ux/utils": "^3.1.1"
	},
	"devDependencies": {
		"@types/react": "^19",
		"builder": "workspace:*",
		"react": "^19",
		"rxjs": "^7",
		"tsup": "^8"
	},
	"peerDependencies": {
		"dedot": "^1"
	}
}
