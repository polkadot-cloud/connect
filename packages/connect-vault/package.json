		"xxhash-wasm": "^1.0.2"
	},
	"devDependencies": {
		"@types/react": "^19",
		"@polkadot-cloud/connect-core": "workspace:*",
		"builder": "workspace:*",
		"react": "^19",
		"tsup": "^8"
	},
	"peerDependencies": {
		"dedot": "^1",
		"@polkadot-cloud/connect": "workspace:*"
	}
