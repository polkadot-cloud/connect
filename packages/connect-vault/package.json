{
	"name": "@polkadot-cloud/connect-vault",
	"description": "Polkadot Vault (QR-based) wallet adaptor for @polkadot-cloud/connect",
	"version": "1.0.0",
	"license": "GPL-3.0-only",
	"type": "module",
	"keywords": [
		"polkadot",
		"substrate",
		"wallet",
		"connect",
		"vault",
		"qrcode",
		"react",
		"typescript"
	],
	"homepage": "https://github.com/polkadot-cloud/connect/tree/main/packages/connect-vault/overview",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/polkadot-cloud/connect.git",
		"directory": "packages/connect-vault"
	},
	"bugs": {
		"url": "https://github.com/polkadot-cloud/connect/issues"
	},
	"scripts": {
		"clear": "rm -rf node_modules dist tsconfig.tsbuildinfo",
		"check": "biome check .",
		"lint": "biome check --write .",
		"build": "tsup",
		"compile": "builder -t connect-vault"
	},
	"dependencies": {
		"html5-qrcode": "^2.3.8",
		"qrcode-generator": "1.5.0",
